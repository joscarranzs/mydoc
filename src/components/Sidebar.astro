---
import { sidebarData } from '../data/sidebar';

const baseUrl = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const modules = sidebarData;
---

<nav class="flex flex-col h-full">
  <!-- Desktop header only -->
  <div class="hidden lg:block bg-dark border-b-2 border-ink px-6 py-4">
      <a href={baseUrl} class="flex items-center gap-2">
      <span class="w-3 h-3 bg-amber rotate-45" />
      <span class="font-bold text-lg tracking-tight text-white">mydocs</span>
    </a>
  </div>

  <!-- Navigation -->
  <div class="flex-1 overflow-y-auto">
    <div class="px-3 sm:px-4 py-5 space-y-6">
      {modules.map((module) => {
        const moduleHref = `${baseUrl}/docs/${module.slug}`;
        const isActive = currentPath.startsWith(moduleHref);

        return (
          <div>
            <a
              href={moduleHref}
              class:list={[
                'block px-3 py-2 text-sm font-bold uppercase tracking-wider transition-colors duration-150 border-l-4',
                isActive
                  ? 'border-amber bg-amber-light text-ink'
                  : 'border-transparent text-ink-light hover:text-ink hover:border-ink-muted',
              ]}
            >
              {module.title}
            </a>

            {module.submodules.length > 0 && (
              <ul class="mt-1.5 space-y-0.5 ml-2">
                {module.submodules.map((sub) => {
                  const href = `${baseUrl}/docs/${module.slug}/${sub.slug}`;
                  const isSubActive = currentPath === href;

                  return (
                    <li>
                      <a
                        href={href}
                        class:list={[
                          'block px-3 py-1 text-sm transition-colors duration-150',
                          isSubActive
                            ? 'text-ink font-bold bg-surface-hover'
                            : 'text-ink-light hover:text-ink',
                        ]}
                      >
                        {sub.title}
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>
        );
      })}
    </div>
  </div>

  <!-- Footer -->
  <div class="hidden lg:block bg-dark border-t-2 border-ink px-6 py-3 text-xs font-semibold text-ink-muted uppercase tracking-wider">
    Astro · docs personales
  </div>
</nav>
