---
import { sidebarData, getAllSubmodules } from '../data/sidebar';
import type { Module } from '../data/sidebar';

const baseUrl = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(/\/+$/, '');
const modules = sidebarData;
---

<nav class="flex flex-col h-full">
  <!-- Desktop header only -->
  <div class="hidden lg:block bg-dark border-b-2 border-ink px-6 py-4">
      <a href={baseUrl} class="flex items-center gap-2">
        <svg class="w-5 h-5 text-amber" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="16 18 22 12 16 6"></polyline>
          <polyline points="8 6 2 12 8 18"></polyline>
        </svg>
        <span class="font-bold text-lg tracking-tight text-white">mydocs</span>
      </a>
  </div>

  <!-- Navigation -->
  <div class="flex-1 overflow-y-auto">
    <div class="px-3 sm:px-4 py-5 space-y-6">
      {modules.map((module: Module) => {
        const moduleHref = `${baseUrl}/docs/${module.slug}`;
        const isActive = currentPath.startsWith(moduleHref);

        return (
          <div>
            <a
              href={moduleHref}
              data-sidebar-module
              class:list={[
                'block px-3 py-2 text-sm font-bold uppercase tracking-wider transition-colors duration-150 border-l-4',
                isActive
                  ? 'border-amber bg-amber-light text-ink'
                  : 'border-transparent text-ink-light hover:text-ink hover:border-ink-muted',
              ]}
            >
              {module.title}
            </a>

            {module.subcategories && module.subcategories.length > 0 ? (
              <ul class="space-y-0.5 mt-1">
                {module.subcategories.map((cat) => {
                  if (cat.submodules.length === 0) return null;

                  return (
                    <li>
                      <div class="px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ink-muted">
                        {cat.title}
                      </div>
                      <ul class="space-y-0.5">
                        {cat.submodules.map((sub) => {
                          const href = `${baseUrl}/docs/${module.slug}/${sub.slug}`;
                          const isSubActive = currentPath === href;

                          return (
                            <li>
                              <a
                                href={href}
                                data-sidebar-sub
                                class:list={[
                                  'block pl-6 pr-3 py-1 text-sm transition-colors duration-150',
                                  isSubActive
                                    ? 'text-ink font-bold bg-amber-light'
                                    : 'text-ink-light hover:bg-amber-light hover:text-ink',
                                ]}
                              >
                                {sub.title}
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    </li>
                  );
                })}
              </ul>
            ) : (
              getAllSubmodules(module).length > 0 && (
                <ul class="space-y-0.5 mt-1">
                  {getAllSubmodules(module).map((sub) => {
                    const href = `${baseUrl}/docs/${module.slug}/${sub.slug}`;
                    const isSubActive = currentPath === href;

                    return (
                      <li>
                        <a
                          href={href}
                          data-sidebar-sub
                          class:list={[
                            'block px-3 py-1 text-sm transition-colors duration-150',
                            isSubActive
                              ? 'text-ink font-bold bg-amber-light'
                              : 'text-ink-light hover:bg-amber-light hover:text-ink',
                          ]}
                        >
                          {sub.title}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )
            )}
          </div>
        );
      })}
    </div>
  </div>

  <!-- Footer -->
  <div class="hidden lg:block bg-dark border-t-2 border-ink px-6 py-3 text-xs font-semibold text-ink-muted uppercase tracking-wider">
    Astro · docs personales
  </div>
</nav>
