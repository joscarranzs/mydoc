---
import { sidebarData } from '../data/sidebar';

const baseUrl = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(/\/+$/, '');

// Group modules by category
const categories = [
  {
    title: 'Lenguajes',
    prefix: 'lenguajes',
    modules: sidebarData.filter(m => m.slug.startsWith('lenguajes/')),
  },
  {
    title: 'Herramientas',
    prefix: 'herramientas',
    modules: sidebarData.filter(m => m.slug.startsWith('herramientas/')),
  },
  {
    title: 'Sistemas',
    prefix: 'sistemas',
    modules: sidebarData.filter(m => m.slug.startsWith('sistemas/')),
  },
];
---

<nav class="flex flex-col h-full">
  <div class="flex-1 overflow-y-auto" data-sidebar-scroll>
    <div class="py-4 space-y-2">
      {categories.map((cat) => {
        return (
          <div>
            <div class="px-6 py-2 text-sm font-bold uppercase tracking-wider text-catblue">
              {cat.title}
            </div>

            <div class="ml-2">
              {cat.modules.map((mod) => {
                const href = `${baseUrl}/docs/${mod.slug}`;
                const isActive = currentPath === href || currentPath.startsWith(href + '/');

                return (
                  <a
                    href={href}
                    data-sidebar-module
                    class:list={[
                      'flex items-center px-6 py-2 text-sm transition-colors duration-150 border-l-2',
                      isActive
                        ? 'border-gblue bg-gblue-50 text-gblue-700 font-medium'
                        : 'border-transparent text-gray-700 hover:bg-gray-100 hover:text-gray-900',
                    ]}
                  >
                    {mod.title}
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</nav>
