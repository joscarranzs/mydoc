---
import { getCollection } from 'astro:content';
import { sidebarData, getAllSubmodules } from '../data/sidebar';
import type { Module, Subcategory } from '../data/sidebar';

const baseUrl = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(/\/+$/, '');
const modules = sidebarData;

const docsEntries = await getCollection('docs');
const existingContent = new Set(docsEntries.map((e) => e.id));

function hasContent(modSlug: string, subSlug: string): boolean {
  return existingContent.has(`${modSlug}/${subSlug}`);
}

function categoryHasContent(modSlug: string, cat: Subcategory): boolean {
  return cat.submodules.some((sub) => hasContent(modSlug, sub.slug));
}

function moduleHasContent(mod: Module): boolean {
  return getAllSubmodules(mod).some((sub) => hasContent(mod.slug, sub.slug));
}
---

<nav class="flex flex-col h-full">
  <!-- Navigation -->
  <div class="flex-1 overflow-y-auto" data-sidebar-scroll>
    <div class="py-4 space-y-1">
      {modules.map((module: Module) => {
        const moduleHref = `${baseUrl}/docs/${module.slug}`;
        const isActive = currentPath.startsWith(moduleHref);
        const hasDirectSubmodules = !module.subcategories && getAllSubmodules(module).length > 0;
        const canCollapseModule = hasDirectSubmodules && moduleHasContent(module);

        return (
          <div>
            <div class="flex items-center">
              <a
                href={moduleHref}
                data-sidebar-module
                class:list={[
                  'block px-6 py-2.5 text-sm font-semibold transition-colors duration-150 flex-1 min-w-0',
                  isActive
                    ? 'border-l-2 border-gblue bg-gblue-50 text-gblue-700'
                    : 'border-l-2 border-transparent text-gray-900 hover:bg-gray-100',
                ]}
              >
                {module.title}
              </a>
              {
                canCollapseModule && (
                  <button
                    data-toggle={module.slug}
                    class="sidebar-toggle-btn shrink-0 mr-2"
                    aria-label="Toggle submodules"
                  >
                    <svg class="w-4 h-4 sidebar-toggle-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </button>
                )
              }
            </div>

            {module.subcategories && module.subcategories.length > 0 ? (
              <ul class="space-y-0.5 mt-2">
                {module.subcategories.map((cat) => {
                  if (cat.submodules.length === 0) return null;

                  const catCanCollapse = categoryHasContent(module.slug, cat);
                  const catKey = `${module.slug}:${cat.title}`;

                  return (
                    <li>
                      {
                        catCanCollapse ? (
                          <>
                            <button
                              data-toggle={catKey}
                              class="sidebar-toggle-btn sidebar-toggle-btn--cat w-full"
                              aria-expanded="false"
                            >
                              <svg class="w-3.5 h-3.5 sidebar-toggle-icon shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                              </svg>
                              {cat.title}
                            </button>
                            <ul class="space-y-0.5 sidebar-content" data-toggle-content={catKey} data-default-collapsed>
                              {cat.submodules.map((sub) => {
                                const href = `${baseUrl}/docs/${module.slug}/${sub.slug}`;
                                const isSubActive = currentPath === href;

                                return (
                                  <li>
                                    <a
                                      href={href}
                                      data-sidebar-sub
                                      class:list={[
                                        'block pl-10 pr-4 py-2 text-sm transition-colors duration-150',
                                        isSubActive
                                          ? 'text-gblue-700 font-medium bg-gblue-50'
                                          : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900',
                                      ]}
                                    >
                                      {sub.title}
                                    </a>
                                  </li>
                                );
                              })}
                            </ul>
                          </>
                        ) : (
                          <>
                            <div class="px-6 py-2 text-xs font-medium uppercase tracking-wider text-gray-500">
                              {cat.title}
                            </div>
                            <ul class="space-y-0.5">
                              {cat.submodules.map((sub) => {
                                const href = `${baseUrl}/docs/${module.slug}/${sub.slug}`;
                                const isSubActive = currentPath === href;

                                return (
                                  <li>
                                    <a
                                      href={href}
                                      data-sidebar-sub
                                      class:list={[
                                        'block pl-10 pr-4 py-2 text-sm transition-colors duration-150',
                                        isSubActive
                                          ? 'text-gblue-700 font-medium bg-gblue-50'
                                          : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900',
                                      ]}
                                    >
                                      {sub.title}
                                    </a>
                                  </li>
                                );
                              })}
                            </ul>
                          </>
                        )
                      }
                    </li>
                  );
                })}
              </ul>
            ) : (
              hasDirectSubmodules && (
                <ul class="space-y-0.5 mt-2" data-toggle-content={module.slug} data-default-collapsed={canCollapseModule || undefined}>
                  {getAllSubmodules(module).map((sub) => {
                    const href = `${baseUrl}/docs/${module.slug}/${sub.slug}`;
                    const isSubActive = currentPath === href;

                    return (
                      <li>
                        <a
                          href={href}
                          data-sidebar-sub
                          class:list={[
                            'block pl-8 pr-4 py-2 text-sm transition-colors duration-150',
                            isSubActive
                              ? 'text-gblue-700 font-medium bg-gblue-50'
                              : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900',
                          ]}
                        >
                          {sub.title}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              )
            )}
          </div>
        );
      })}
    </div>
  </div>
</nav>

<script>
  const TOGGLE_KEY = 'mydocs:sidebar-toggles';
  const SCROLL_KEY = 'mydocs:sidebar-scroll';

  function loadSavedState() {
    try {
      return JSON.parse(localStorage.getItem(TOGGLE_KEY) || '{}');
    } catch {
      return {};
    }
  }

  function saveToggle(key, open) {
    try {
      const state = loadSavedState();
      state[key] = open;
      localStorage.setItem(TOGGLE_KEY, JSON.stringify(state));
    } catch {}
  }

  function setupToggles() {
    const saved = loadSavedState();

    document.querySelectorAll('[data-toggle]').forEach((btn) => {
      const key = btn.dataset.toggle;
      const content = document.querySelector(`[data-toggle-content="${CSS.escape(key)}"]`);
      if (!content) return;

      const icon = btn.querySelector('.sidebar-toggle-icon');
      const isInitialized = btn.dataset.toggleInit === 'true';

      const setOpen = (open) => {
        content.classList.toggle('sidebar-content--open', open);
        btn.setAttribute('aria-expanded', String(open));
        if (icon) {
          icon.style.transform = open ? 'rotate(90deg)' : 'rotate(0deg)';
        }
        saveToggle(key, open);
      };

      if (!isInitialized) {
        let isOpen;

        if (key in saved) {
          isOpen = saved[key];
        } else {
          const isDefaultCollapsed = content.dataset.defaultCollapsed !== undefined;
          isOpen = !isDefaultCollapsed;
        }

        setOpen(isOpen);
        btn.dataset.toggleInit = 'true';

        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = content.classList.contains('sidebar-content--open');
          setOpen(!isOpen);
        });
      }
    });
  }

  function saveScroll() {
    const el = document.querySelector('[data-sidebar-scroll]');
    if (el) {
      localStorage.setItem(SCROLL_KEY, String(el.scrollTop));
    }
  }

  function restoreScroll() {
    const saved = localStorage.getItem(SCROLL_KEY);
    if (!saved) return;
    const el = document.querySelector('[data-sidebar-scroll]');
    if (el) {
      el.scrollTop = parseInt(saved, 10);
    }
  }

  document.addEventListener('DOMContentLoaded', setupToggles);
  document.addEventListener('astro:before-swap', saveScroll);

  document.addEventListener('astro:page-load', () => {
    setupToggles();
    restoreScroll();
  });
</script>
