---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sidebarData, getAllSubmodules } from '../data/sidebar';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="Inicio" description="Documentación personal de programación.">
  <div class="space-y-10 sm:space-y-12">
    <!-- Hero -->
    <section class="space-y-5 sm:space-y-6">
      <div class="inline-flex items-center gap-2 border-2 border-ink bg-amber-light px-3 sm:px-4 py-1 sm:py-1.5 text-2xs sm:text-xs font-bold uppercase tracking-wider">
        <span class="w-1.5 sm:w-2 h-1.5 sm:h-2 bg-amber rotate-45" />
        base de conocimiento personal
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter leading-[0.95] text-ink">
        <span class="flicker">bienvenido a</span>
        <span class="glitch block mt-1 text-amber" data-text="mydocs">mydocs</span>
      </h1>
      <p class="text-xs sm:text-sm font-bold text-ink-muted uppercase tracking-[0.2em] border-l-2 border-ink pl-2 sm:pl-3">
        by MR CARRANZA
      </p>

      <p class="text-sm sm:text-base md:text-lg text-ink-light max-w-xl leading-relaxed border-l-4 border-amber pl-3 sm:pl-4">
        Una colección personal de notas, patrones y referencias de programación
        — documentadas y organizadas a mi manera.
      </p>

      <div class="flex flex-wrap gap-2 sm:gap-3">
        {sidebarData.map((mod) => (
          <a
            href={`${baseUrl}/docs/${mod.slug}`}
            class="inline-flex items-center gap-1.5 sm:gap-2 border-2 border-ink bg-surface-card px-4 sm:px-5 py-2 sm:py-2.5 text-xs sm:text-sm font-bold
                   text-ink hover:bg-amber hover:text-white hover:shadow-brutal-hover
                   hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all duration-150"
          >
            {mod.title}
            <svg class="w-3.5 sm:w-4 h-3.5 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </section>

    <!-- Explore -->
    {sidebarData.length > 0 && (
      <section class="space-y-4">
        <h2 class="text-2xs sm:text-xs font-bold text-ink tracking-widest uppercase border-b-2 border-ink pb-2">
          explorar
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          {sidebarData.map((mod) => (
            <a
              href={`${baseUrl}/docs/${mod.slug}`}
              class="brutal-card p-4 sm:p-5 block hover:shadow-brutal-hover hover:-translate-x-0.5 hover:-translate-y-0.5
                     transition-all duration-150"
            >
              <h3 class="font-bold text-base sm:text-lg text-ink mb-1">{mod.title}</h3>
              {mod.description && <p class="text-xs sm:text-sm text-ink-light mb-2 sm:mb-3">{mod.description}</p>}
              {(() => { const subs = getAllSubmodules(mod); return subs.length > 0 && (
                <ul class="space-y-1">
                  {subs.slice(0, 4).map((sub) => (
                    <li class="flex items-center gap-2 text-xs sm:text-sm text-ink-light">
                      <span class="w-1 sm:w-1.5 h-1 sm:h-1.5 bg-amber rotate-45 shrink-0" />
                      {sub.title}
                    </li>
                  ))}
                  {subs.length > 4 && (
                    <li class="text-xs sm:text-sm font-bold text-amber">
                      +{subs.length - 4} más
                    </li>
                  )}
                </ul>
              )})()}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Footer -->
    <section class="border-t-2 border-ink pt-5 sm:pt-6">
      <div class="flex flex-wrap items-center gap-2 sm:gap-3 text-2xs sm:text-xs font-semibold text-ink-muted uppercase tracking-wider">
        <span class="w-1.5 sm:w-2 h-1.5 sm:h-2 bg-amber rotate-45 shrink-0" />
        built with Astro
        <span class="w-1.5 sm:w-2 h-1.5 sm:h-2 bg-amber rotate-45 shrink-0" />
        {sidebarData.length} seccion{sidebarData.length !== 1 ? 'es' : ''}
        <span class="w-1.5 sm:w-2 h-1.5 sm:h-2 bg-amber rotate-45 shrink-0" />
        {sidebarData.reduce((acc, m) => acc + getAllSubmodules(m).length, 0)} articulo{sidebarData.reduce((acc, m) => acc + getAllSubmodules(m).length, 0) !== 1 ? 's' : ''}
      </div>
    </section>
  </div>
</BaseLayout>
