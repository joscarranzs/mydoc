---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;

const languages = [
  { title: 'HTML', desc: 'Lenguaje de marcado para la web.' },
  { title: 'CSS', desc: 'Lenguaje de estilos para la web.' },
  { title: 'JavaScript', desc: 'Lenguaje de programación web por excelencia.' },
  { title: 'TypeScript', desc: 'JavaScript con tipos estáticos.' },
  { title: 'Python', desc: 'Versátil, simple y poderoso.' },
  { title: 'Java', desc: 'Lenguaje orientado a objetos, multiplataforma.' },
  { title: 'C', desc: 'Lenguaje de bajo nivel, base de muchos sistemas.' },
  { title: 'Rust', desc: 'Seguridad y rendimiento sin basura.' },
  { title: 'Lua', desc: 'Pequeño, rápido y embebible.' },
];
---

<BaseLayout title="Inicio">
  <div class="space-y-20">

    <!-- Hero -->
    <section class="space-y-5">
      <p class="section-label">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        mydocs
      </p>
      <h1 class="text-5xl font-semibold tracking-tight text-white sm:text-6xl md:text-7xl md:leading-[1.05]">
        Guías de programación.
      </h1>
      <p class="text-lg leading-relaxed text-swift-muted sm:text-xl sm:leading-8">
        Contenido técnico estructurado para aprender programación de forma progresiva y sólida.
      </p>
    </section>

    <!-- Overview cards -->
    <section class="space-y-6">
      <p class="section-label">Lenguajes</p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {languages.map((lang) => {
          let slug = '#';
          if (lang.title === 'HTML') slug = `${base}docs/html`;
          if (lang.title === 'CSS') slug = `${base}docs/css`;
          if (lang.title === 'JavaScript') slug = `${base}docs/javascript`;
          return (
          <a href={slug} class="doc-card no-underline">
            <span class="doc-card-icon">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </span>
            <div class="space-y-1">
              <h2 class="text-base font-semibold text-white">{lang.title}</h2>
              <p class="text-sm leading-relaxed text-swift-muted">{lang.desc}</p>
            </div>
          </a>
          );
        })}
      </div>
    </section>

    <!-- More sections placeholder -->
    <section class="space-y-6">
      <p class="section-label">Herramientas</p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="#" class="doc-card no-underline">
          <span class="doc-card-icon">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
            </svg>
          </span>
          <div class="space-y-1">
            <h2 class="text-base font-semibold text-white">Git</h2>
            <p class="text-sm leading-relaxed text-swift-muted">Control de versiones distribuido.</p>
          </div>
        </a>

        <a href="#" class="doc-card no-underline">
          <span class="doc-card-icon">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </span>
          <div class="space-y-1">
            <h2 class="text-base font-semibold text-white">VIM</h2>
            <p class="text-sm leading-relaxed text-swift-muted">Editor de texto en terminal.</p>
          </div>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
