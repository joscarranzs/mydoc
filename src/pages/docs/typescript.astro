---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicNav from '../../components/TopicNav.astro';
---

<BaseLayout title="TypeScript" description="Tutorial completo de TypeScript">
  <div class="mx-auto max-w-3xl space-y-5">
    <p class="section-label">TypeScript</p>
    <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl md:text-6xl">
      Tutorial de TypeScript.
    </h1>
    <p class="text-lg leading-relaxed text-swift-muted sm:text-xl">
      TypeScript extiende JavaScript con tipos estáticos. Aprende desde tipos básicos hasta patterns avanzados y herramientas del ecosistema.
    </p>
  </div>

  <div class="mx-auto mt-16 max-w-5xl">
    <TopicNav currentSlug="typescript" />
  </div>
</BaseLayout>
