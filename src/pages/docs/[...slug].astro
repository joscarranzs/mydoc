---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageNav from '../../components/PageNav.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '').replace(/\/?index$/, '') },
    props: { entryId: entry.id },
  }));
}

const { entryId } = Astro.props;
const entry = await getEntry('docs', entryId);
const fullSlug = entry!.id.replace(/\.md$/, '');
const { Content } = await render(entry!);
---

<BaseLayout title={entry!.data.title} description={entry!.data.description}>
  <article class="prose-custom mx-auto max-w-3xl">
    <Content />
  </article>
  <div class="mx-auto max-w-3xl">
    <PageNav currentSlug={fullSlug} />
  </div>
</BaseLayout>
