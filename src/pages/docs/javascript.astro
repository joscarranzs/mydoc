---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicNav from '../../components/TopicNav.astro';
---

<BaseLayout title="JavaScript" description="Tutorial completo de JavaScript">
  <div class="mx-auto max-w-3xl space-y-5">
    <p class="section-label">JavaScript</p>
    <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl md:text-6xl">
      Tutorial de JavaScript.
    </h1>
    <p class="text-lg leading-relaxed text-swift-muted sm:text-xl">
      JavaScript es el lenguaje de programación de la web. Aprende desde fundamentos hasta asincronía, DOM, APIs y patrones avanzados.
    </p>
  </div>

  <div class="mx-auto mt-16 max-w-5xl">
    <TopicNav currentSlug="javascript" />
  </div>
</BaseLayout>
