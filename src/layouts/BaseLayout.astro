---
import '../styles/global.css';
import { Icon } from 'astro-icon/components';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
}

const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="description" content={description ?? 'Documentación personal de programación'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <title>{title} · mydocs</title>
  </head>
  <body>
    <header class="border-b border-swift-border bg-swift-bg">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href={baseUrl} class="flex items-center gap-2 text-sm font-semibold text-white no-underline">
          <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-white text-black">
            <Icon name="ph:globe-simple" class="h-5 w-5" />
          </span>
          mydocs
        </a>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-12 sm:py-16">
      <slot />
    </main>
  </body>
</html>
